#!/data/data/com.termux/files/usr/bin/bash
# npmpub - combined local + remote
VERSION="${1#v}"
if [ ! -f "./package.json" ]; then echo "package.json missing"; exit 1; fi
if command -v jq >/dev/null 2>&1; then jq --arg ver "$VERSION" '.version=$ver' package.json > package.tmp.json && mv package.tmp.json package.json
else sed -i "s/\"version\": \".*\"/\"version\": \"$VERSION\"/" package.json; fi
npm publish
echo "✅ Published $VERSION"
